{
  "name": "terminal-translator",
  "version": "1.0.0",
  "description": "终端实时翻译助手 — 英文终端输出实时翻译成中文，支持智能代码识别、教学模式、多模型切换",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --enable-logging",
    "build": "electron-builder --mac",
    "build:x64": "electron-builder --mac --x64",
    "build:arm64": "electron-builder --mac --arm64"
  },
  "build": {
    "appId": "com.terminal-translator.app",
    "productName": "Terminal Translator",
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg"
      ]
    },
    "dmg": {
      "title": "Terminal Translator",
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "renderer.js",
      "node_modules/@xterm/**",
      "node_modules/node-pty/**"
    ]
  },
  "keywords": [
    "terminal",
    "translator",
    "electron",
    "chinese",
    "deepseek",
    "openai",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": ""
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1"
  }
}
